<?xml version="1.0"?>
<ruleset name="Patcherly WordPress Connector">
    <description>PHPCS rules for the WP.org distribution tree. Excludes dev-only paths not shipped in patcherly.zip.</description>

    <file>.</file>

    <exclude-pattern>tests/*</exclude-pattern>
    <exclude-pattern>.distignore</exclude-pattern>
    <exclude-pattern>phpcs.xml.dist</exclude-pattern>
    <exclude-pattern>languages/*</exclude-pattern>

    <rule ref="WordPress"/>
</ruleset>
